{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "InventPay",
  "colors": {
    "primary": "#16A34A",
    "light": "#22C55E",
    "dark": "#15803D"
  },
  "favicon": "/inventpay-svg.svg",
  "api": {
    "mdx": {
      "server": "https://api.inventpay.io",
      "auth": {
        "method": "key",
        "name": "X-API-Key"
      }
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quickstart", "mcp-server"]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/payments",
              "concepts/currencies",
              "concepts/balances",
              "concepts/withdrawals",
              "concepts/store"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "webhooks/overview",
              "webhooks/setup",
              "webhooks/events",
              "webhooks/security"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Payments",
            "pages": [
              "api-reference/create-payment",
              "api-reference/create-invoice",
              "api-reference/get-payment-status"
            ]
          },
          {
            "group": "Balances",
            "pages": [
              "api-reference/get-balances",
              "api-reference/get-balance-by-currency"
            ]
          },
          {
            "group": "Withdrawals",
            "pages": [
              "api-reference/create-withdrawal",
              "api-reference/get-withdrawal"
            ]
          },
          {
            "group": "Store",
            "pages": [
              "api-reference/store/create-store",
              "api-reference/store/get-store",
              "api-reference/store/update-store",
              "api-reference/store/create-product",
              "api-reference/store/list-products",
              "api-reference/store/get-product",
              "api-reference/store/update-product",
              "api-reference/store/delete-product",
              "api-reference/store/add-product-keys",
              "api-reference/store/list-product-keys",
              "api-reference/store/get-key-pool-stats",
              "api-reference/store/remove-product-keys",
              "api-reference/store/checkout",
              "api-reference/store/order-status",
              "api-reference/store/download",
              "api-reference/store/list-orders",
              "api-reference/store/get-order",
              "api-reference/store/update-order-status",
              "api-reference/store/get-public-store"
            ]
          }
        ]
      },
      {
        "tab": "SDKs",
        "groups": [
          {
            "group": "Overview",
            "pages": ["sdks/overview"]
          },
          {
            "group": "JavaScript/TypeScript",
            "pages": [
              "sdks/javascript/installation",
              "sdks/javascript/configuration",
              "sdks/javascript/usage",
              "sdks/javascript/examples"
            ]
          },
          {
            "group": "Python",
            "pages": [
              "sdks/python/installation",
              "sdks/python/configuration",
              "sdks/python/usage",
              "sdks/python/examples"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/inventpay-new1.jpg",
    "dark": "/logo/inventpay-new1.jpg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@inventpay.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://inventpay.io/dashboard"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "mcp",
      "chatgpt",
      "claude",
      "perplexity",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/inventpay",
      "github": "https://github.com/inventpay",
      "linkedin": "https://linkedin.com/company/inventpay"
    }
  }
}
