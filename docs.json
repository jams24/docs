          {
            "group": "Core Concepts",
            "pages": [
              "concepts/payments",
              "concepts/currencies",
              "concepts/balances",
              "concepts/withdrawals"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "webhooks/overview",
              "webhooks/setup",
              "webhooks/events",
              "webhooks/security"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Payments",
            "pages": [
              "api-reference/create-payment",
              "api-reference/create-invoice",
              "api-reference/get-payment-status"
            ]
          },
          {
            "group": "Balances",
            "pages": [
              "api-reference/get-balances",
              "api-reference/get-balance-by-currency"
            ]
          },
          {
            "group": "Withdrawals",
            "pages": [
              "api-reference/create-withdrawal",
              "api-reference/get-withdrawal"
            ]
          }
        ]
      },
      {
        "tab": "SDKs",
        "groups": [
          {
            "group": "Overview",
            "pages": ["sdks/overview"]
          },
          {
            "group": "JavaScript/TypeScript",
            "pages": [
              "sdks/javascript/installation",
              "sdks/javascript/configuration",
              "sdks/javascript/usage",
              "sdks/javascript/examples"
            ]
          },
          {
            "group": "Python",
            "pages": [
              "sdks/python/installation",
              "sdks/python/configuration",
              "sdks/python/usage",
              "sdks/python/examples"
            ]
          }
        ]
      }
    ]
